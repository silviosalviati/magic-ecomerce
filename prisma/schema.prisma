datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  orders    Order[]
}

model Product {
  id          String    @id @default(uuid())
  name        String
  description String?
  category    String
  basePrice   Decimal  @db.Decimal(10, 2)
  costPrice   Decimal  @db.Decimal(10, 2)
  markup      Decimal
  images      String[]
  createdAt   DateTime  @default(now())
  variants    Variant[]
}

model Variant {
  id         String      @id @default(uuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id])
  size       String
  color      String
  barcode    String?     @unique
  stock      Int         @default(0)
  orderItems OrderItem[]
}

model Order {
  id           String      @id @default(uuid())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  items        OrderItem[]
  total        Decimal
  status       String      @default("PENDING")
  paymentId    String?
  guestName    String?
  guestEmail   String?
  guestCpf     String?
  pixQrCode     String?
  pixCopyPaste  String?
  pixExpiresAt  DateTime?
  paymentMethod String?
  boletoUrl     String?
  boletoBarcode String?
  boletoDueDate DateTime?
  createdAt     DateTime    @default(now())
  // Entrega
  shippingMethod      String?
  trackingCode        String?
  trackingUrl         String?
  // Endereço de entrega
  addressStreet       String?
  addressNumber       String?
  addressComplement   String?
  addressNeighborhood String?
  addressCity         String?
  addressState        String?
  addressZip          String?
  statusUpdates       OrderStatusUpdate[]
}

model OrderStatusUpdate {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  status    String
  note      String?
  createdAt DateTime @default(now())
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id])
  variantId       String
  variant         Variant @relation(fields: [variantId], references: [id])
  quantity        Int
  priceAtPurchase Decimal
}